import { defineBuildConfig, stripIfDisabled, dropFiles } from "@zenbujs/cli/build";

/**
 * Build pipeline for `zen build:source` and `zen build:desktop`.
 *
 * Edit `include`/`ignore` to choose what gets shipped to the mirror repo and
 * seeded inside the .app. Add transforms to strip feature-flagged code,
 * drop test files, etc.
 *
 * Set `mirror.target` to "<owner>/<repo>" (a GitHub repo) to enable
 * `zen publish:source init` / `zen publish:source push`.
 */
export default defineBuildConfig({
  source: ".",
  out: ".zenbu/source",

  include: [
    "src/**/*",
    "package.json",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "zenbu.plugin.json",
    "config.json",
    "db/**",
    "db.config.ts",
    "vite.config.ts",
    "loading.html",
  ],
  ignore: [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/dev-only/**",
  ],

  transforms: [
    // Marker-based feature stripping. Lines between
    //   // @zenbu:strip-if !FLAG_BETA
    //   ...
    //   // @zenbu:end
    // are removed when FLAG_BETA is false.
    stripIfDisabled({ FLAG_BETA: false }),
    dropFiles(/\.stories\.tsx?$/),
  ],

  // mirror: { target: "{{owner}}/{{repo}}", branch: "main" },
});
