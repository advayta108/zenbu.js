{
  "name": "create-zenbu-app",
  "version": "0.0.11",
  "description": "Scaffold a new Zenbu app",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-zenbu-app": "./dist/index.mjs"
  },
  "files": [
    "dist/",
    "templates/"
