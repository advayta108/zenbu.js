{
  "name": "@zenbujs/core",
  "version": "0.0.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/setup-gate.mjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./setup-gate": {
      "types": "./src/setup-gate.ts",
      "import": "./dist/setup-gate.mjs"
    },
    "./loaders/zenbu": {
      "types": "./src/loaders/zenbu.ts",
      "import": "./dist/loaders/zenbu.mjs"
    },
    "./env-bootstrap": {
      "types": "./src/env-bootstrap.ts",
      "import": "./dist/env-bootstrap.mjs"
    },
    "./runtime": {
      "types": "./src/runtime.ts",
      "import": "./dist/runtime.mjs"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "import": "./dist/registry.mjs"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./dist/schema.mjs"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "import": "./dist/services/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "scripts",
    "setup",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "link:types": "node ../zen/dist/bin.mjs link --types-config ./zenbu-types.config.json --registry ./types",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings=0"
  },
  "peerDependencies": {
    "electron": "^42.0.0"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.0",
    "@vitejs/plugin-react": "^5.0.0",
    "dugite": "^3.2.1",
    "effect": "^3.21.1",
    "dynohot": "workspace:*",
    "nanoid": "^5.1.6",
    "tsx": "^4.21.0",
    "vite": "^6.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "@zenbu/advice": "workspace:*",
    "@zenbu/git": "workspace:*",
    "@zenbu/kyju": "workspace:*",
    "@zenbu/zenrpc": "workspace:*",
    "@zenbu/lint": "workspace:*",
    "electron": "^42.0.0",
    "eslint": "^9.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.4.5"
  }
}
