import type { ReactNode } from "react"

/**
 * Sample `around` advice: wraps the original component output with extra
 * markup. `Original` is the target component; invoke it with the props you
 * received and compose additional UI around it.
 */
export function TitleBarWrapper(Original: any, props: any): ReactNode {
  return (
    <div style={{ outline: "2px solid deeppink" }}>
      {Original(props)}
    </div>
  )
}
