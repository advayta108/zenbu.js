#!/usr/bin/env bun
/**
 * {{name}} setup script.
 *
 * Runs via the cached bun binary (`~/Library/Caches/Zenbu/bin/bun`) — either
 * automatically on `setup.version` bumps or manually via `zen setup`.
 *
 * Idempotent: every step reads state first and no-ops when satisfied.
 */

import fs from "node:fs"
import path from "node:path"
import { fileURLToPath } from "node:url"

const PLUGIN_ROOT = path.dirname(fileURLToPath(import.meta.url))

const stepStart = (id: string, label: string) =>
  console.log(`##ZENBU_STEP:start:${id}:${label}`)
const stepDone = (id: string) => console.log(`##ZENBU_STEP:done:${id}`)
const stepError = (id: string, msg: string) =>
  console.log(`##ZENBU_STEP:error:${id}:${msg}`)

async function runStep(id: string, label: string, fn: () => Promise<void>) {
  stepStart(id, label)
  try {
    await fn()
    stepDone(id)
  } catch (err) {
    stepError(id, err instanceof Error ? err.message : String(err))
    process.exit(1)
  }
}

async function ensureDeps() {
  const pnpmBin = path.join(
    process.env.HOME ?? "",
    "Library",
    "Caches",
    "Zenbu",
    "bin",
    "pnpm",
  )
  const pnpm = fs.existsSync(pnpmBin) ? pnpmBin : "pnpm"
  const proc = Bun.spawn([pnpm, "install", "--no-frozen-lockfile"], {
    cwd: PLUGIN_ROOT,
    env: { ...process.env, CI: "true" },
    stdio: ["ignore", "inherit", "inherit"],
  })
  const exit = await proc.exited
  if (exit !== 0) throw new Error(`pnpm install exited with code ${exit}`)
}

async function main() {
  process.chdir(PLUGIN_ROOT)
  await runStep("deps", "Installing {{name}} deps", ensureDeps)
  console.log("\n##ZENBU_STEP:all-done")
}

main().catch((err) => {
  console.error(err)
  process.exit(1)
})
