{
  "name": "@zenbujs/cli",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "zen": "./dist/bin.mjs"
  },
  "main": "./dist/bin.mjs",
  "exports": {
    ".": {
      "import": "./dist/bin.mjs"
    },
    "./build": {
      "import": "./dist/build.mjs"
    },
    "./launcher": {
      "import": "./dist/launcher.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings=0"
  },
  "dependencies": {
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^22.0.0",
    "@zenbu/kyju": "workspace:*",
    "@zenbu/lint": "workspace:*",
    "@zenbu/zenrpc": "workspace:*",
    "electron": "^42.0.0",
    "eslint": "^9.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.0.0"
  }
}
