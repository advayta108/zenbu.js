{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "typeRoots": [
      "../../node_modules/@types",
      "../../apps/kernel/node_modules"
    ],
    "paths": {
      "#zenbu/*": ["../../packages/*"]
    }
  },
  "include": ["src"]
}
